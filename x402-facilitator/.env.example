# Required — 32-byte hex private key for the facilitator wallet
FACILITATOR_PRIVATE_KEY=0x...

# RPC URLs — at least one chain must be enabled with its RPC URL
BASE_RPC_URL=https://mainnet.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Server
PORT=3402
HOST=0.0.0.0

# Feature flags — enable/disable chains
ENABLE_BASE=true
ENABLE_BASE_SEPOLIA=false
ENABLE_ARBITRUM=false
ENABLE_ARBITRUM_SEPOLIA=false
ENABLE_ETHEREUM=false

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=info

# Optional — Redis for distributed rate limiting
# REDIS_URL=redis://localhost:6379
